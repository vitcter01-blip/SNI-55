# Скопируйте этот файл в .env и заполните значения
# cp .env.example bot/.env

# ── Обязательные ─────────────────────────────────────────────────────────────
TG_BOT_TOKEN=1234567890:AAF_ваш_токен_от_BotFather
TG_ADMIN_IDS=123456789                  # ваш Telegram user_id (через запятую для нескольких)

# ── SSH (опционально, по умолчанию: root / порт 22) ───────────────────────────
SSH_USER=root
SSH_PORT=22

# ── Воркер (опционально) ──────────────────────────────────────────────────────
REMOTE_DIR=/opt/sni_worker              # куда деплоить на удалённых серверах
SNI_CONCURRENCY=50                      # параллельность проверок

# ── История ──────────────────────────────────────────────────────────────────
HISTORY_KEEP=20                         # сколько последних проверок хранить
